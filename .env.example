# Plantilla de variables de entorno.
# Copia este archivo a `.env` y reemplaza los valores reales.
# `.env` esta gitignored y no debe comitearse jamas.
#
# Sintaxis: prefijo PROCESSOR_ + ruta_anidada con __ como separador.
# Cualquier campo de config.yaml puede sobreescribirse por esta via.

# --- Telegram (opcional) ---
# PROCESSOR_TELEGRAM__ENABLED=true
# PROCESSOR_TELEGRAM__BOT_TOKEN=<token de BotFather>
# PROCESSOR_TELEGRAM__CHAT_ID=<id numerico del chat>
# PROCESSOR_TELEGRAM__MIN_SEVERITY=warning   # warning | critical

# --- Otros overrides comunes ---
# PROCESSOR_LOKI__URL=http://localhost:13100
# PROCESSOR_PROCESSOR__SCHEDULE_INTERVAL_MINUTES=1
# PROCESSOR_PROCESSOR__DEFAULTS__THRESHOLD_K=2.5
# PROCESSOR_LOGGING__LEVEL=DEBUG
