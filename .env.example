# =============================================================================
# .env.example — Copiar a .env y ajustar los valores.
# =============================================================================

# -----------------------------------------------------------------------------
# PERFIL DE ENTORNO
# -----------------------------------------------------------------------------
# local       -> W=1min, H=1dia,  k=2.0, min_obs=3
# development -> W=2min, H=3dias, k=2.5, min_obs=5
# production  -> W=5min, H=7dias, k=3.0, min_obs=10
PROCESSOR_ENV=development

# -----------------------------------------------------------------------------
# LOKI  (obligatorio — el pod no arranca sin esto)
# -----------------------------------------------------------------------------
PROCESSOR_LOKI__URL=http://172.16.0.3:30100

# -----------------------------------------------------------------------------
# TELEGRAM  (opcional — si ENABLED=true, BOT_TOKEN y CHAT_ID son obligatorios)
# -----------------------------------------------------------------------------
PROCESSOR_TELEGRAM__ENABLED=true
PROCESSOR_TELEGRAM__BOT_TOKEN=8725237844:AAHV_XIcT9hbf9Qt8fqVd-SKywKtqMChwbk
PROCESSOR_TELEGRAM__CHAT_ID=1269236635
PROCESSOR_TELEGRAM__MIN_SEVERITY=warning

# -----------------------------------------------------------------------------
# ALERTMANAGER  (opcional — deshabilitado por defecto)
# -----------------------------------------------------------------------------
# PROCESSOR_ALERTMANAGER__ENABLED=true
# PROCESSOR_ALERTMANAGER__URL=http://alertmanager:9093

# -----------------------------------------------------------------------------
# PROMETHEUS METRICS
# -----------------------------------------------------------------------------
# PROCESSOR_METRICS__PORT=8000

# -----------------------------------------------------------------------------
# OVERRIDES PUNTUALES
# -----------------------------------------------------------------------------
# PROCESSOR_PROCESSOR__DEFAULTS__THRESHOLD_K=2.0
# PROCESSOR_PROCESSOR__DEFAULTS__MIN_OBSERVATIONS=3
# PROCESSOR_PROCESSOR__SCHEDULE_INTERVAL_MINUTES=1
# PROCESSOR_PROCESSOR__HISTORY_DAYS=1
