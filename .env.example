# =============================================================================
# .env.example — Configuracion de entorno del procesador de anomalias
#
# Copiar a .env y ajustar. El .env esta en .gitignore (nunca commitear tokens).
# =============================================================================

# -----------------------------------------------------------------------------
# PERFIL DE ENTORNO
# -----------------------------------------------------------------------------
# Controla los parametros del algoritmo de deteccion segun el contexto de uso.
# Si no se define, usa "production" (mas conservador = menos falsos positivos).
#
# local       -> W=1min, H=1dia,  k=2.0, min_obs=3,  DEBUG, info+warn+error
# development -> W=2min, H=3dias, k=2.5, min_obs=5,  INFO,  warn+error
# production  -> W=5min, H=7dias, k=3.0, min_obs=10, INFO,  warn+error (JSON)
#
# Resumen de diferencias:
#   local:       Ve anomalias en ~3 ciclos (3 min). Mucho ruido, util para
#                verificar que el pipeline funciona end-to-end rapidamente.
#   development: Ve anomalias en ~10 min. Balance sensibilidad/precision.
#                Recomendado para iterar sobre la logica de deteccion.
#   production:  Ve anomalias en ~50 min (necesita 10 ciclos de historia).
#                Minimos falsos positivos. Para uso real con logs reales.
#
PROCESSOR_ENV=local


# -----------------------------------------------------------------------------
# NOTIFICACIONES TELEGRAM (opcional)
# -----------------------------------------------------------------------------
# 1. Crear bot en @BotFather -> copiar el token
# 2. Iniciar conversacion con el bot (/start)
# 3. Obtener chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
#
PROCESSOR_TELEGRAM__ENABLED=true
PROCESSOR_TELEGRAM__BOT_TOKEN=
PROCESSOR_TELEGRAM__CHAT_ID=
# "warning" = envia todas las anomalias
# "critical" = solo las de z >= 5 (spikes extremos, servicios caidos)
PROCESSOR_TELEGRAM__MIN_SEVERITY=warning


# -----------------------------------------------------------------------------
# LOKI (si no usas SSH tunnel o cambia el puerto)
# -----------------------------------------------------------------------------
# PROCESSOR_LOKI__URL=http://localhost:13100


# -----------------------------------------------------------------------------
# OVERRIDES DEL ALGORITMO (opcional, sobreescriben el perfil PROCESSOR_ENV)
# -----------------------------------------------------------------------------
# Usar solo si necesitas un valor especifico que el perfil no da.
# Ejemplos:
#   PROCESSOR_PROCESSOR__DEFAULTS__THRESHOLD_K=2.0
#   PROCESSOR_PROCESSOR__DEFAULTS__MIN_OBSERVATIONS=5
#   PROCESSOR_PROCESSOR__DEFAULTS__MIN_COUNT=1.5
#   PROCESSOR_PROCESSOR__DEFAULTS__MIN_DELTA=2
#   PROCESSOR_PROCESSOR__SCHEDULE_INTERVAL_MINUTES=1
#   PROCESSOR_PROCESSOR__HISTORY_DAYS=1
