# =============================================================================
# .env.example — Copy to .env and fill in your values.
# Variables marked (required) will cause a startup error if not set.
# =============================================================================

# -----------------------------------------------------------------------------
# LOKI  (required)
# -----------------------------------------------------------------------------
# The processor will not start without this value.
#
PROCESSOR_LOKI__URL=http://localhost:13100                         # required

# Label Loki uses to identify the service.


# -----------------------------------------------------------------------------
# ENVIRONMENT PROFILE  (optional — defaults to "production")
# -----------------------------------------------------------------------------
# Controls algorithm sensitivity and cycle speed.
#
#   local       → 1 min cycle · 1 day history  · k=2.0 · min_obs=3  · DEBUG
#   development → 2 min cycle · 3 day history  · k=2.5 · min_obs=5  · INFO
#   production  → 5 min cycle · 7 day history  · k=3.0 · min_obs=10 · INFO/JSON
#
PROCESSOR_ENV=development


# -----------------------------------------------------------------------------
# TELEGRAM  (optional)
# -----------------------------------------------------------------------------
# If ENABLED=true, BOT_TOKEN and CHAT_ID are required.
# Get a bot token from @BotFather. Get your chat ID from @userinfobot.
#
PROCESSOR_TELEGRAM__ENABLED=true
PROCESSOR_TELEGRAM__BOT_TOKEN=8725237844:AAHV_XIcT9hbf9Qt8fqVd-SKywKtqMChwbk
PROCESSOR_TELEGRAM__CHAT_ID=1269236635
PROCESSOR_TELEGRAM__MIN_SEVERITY=warning

# -----------------------------------------------------------------------------
# ALERTMANAGER  (optional — disabled by default)
# -----------------------------------------------------------------------------
# Enable only if you have an AlertManager instance.
# If ENABLED=true, URL is required.
#
# PROCESSOR_ALERTMANAGER__ENABLED=true
# PROCESSOR_ALERTMANAGER__URL=http://alertmanager:9093   # required if enabled


# -----------------------------------------------------------------------------
# PROMETHEUS METRICS  (optional — enabled on port 8000 by default)
# -----------------------------------------------------------------------------
# The processor exposes /metrics at http://localhost:<PORT>/metrics.
# Scrape it with Prometheus or check it manually.
#
# PROCESSOR_METRICS__ENABLED=true
# PROCESSOR_METRICS__PORT=8000


# -----------------------------------------------------------------------------
# ALGORITHM OVERRIDES  (optional — override specific values without changing profile)
# -----------------------------------------------------------------------------
# PROCESSOR_PROCESSOR__DEFAULTS__THRESHOLD_K=2.0
# PROCESSOR_PROCESSOR__DEFAULTS__MIN_OBSERVATIONS=5
# PROCESSOR_PROCESSOR__DEFAULTS__MIN_COUNT=1.5
# PROCESSOR_PROCESSOR__DEFAULTS__MIN_DELTA=2
# PROCESSOR_PROCESSOR__SCHEDULE_INTERVAL_MINUTES=1
# PROCESSOR_PROCESSOR__HISTORY_DAYS=1
