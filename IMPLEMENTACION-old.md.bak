### Paso 3 — `processor/pre_parser.py`

Normaliza los 2 perfiles. Devuelve siempre un dict con `level`, `context`, `message`.

Ver el código detallado en `../alloy/PERFILES-LOG-TECOPOS.md` — las funciones `parse_nestjs()` y `parse_winston()` ya están documentadas ahí.

```python
import re
import json

ANSI_ESCAPE = re.compile(r'\x1b\[[0-9;]*m')
NESTJS_PATTERN = re.compile(
    r'^\[Nest\]\s+\d+\s+-\s+[\d/,: ]+\s+'
    r'(?P<level>LOG|WARN|ERROR|DEBUG|VERBOSE)\s+'
    r'\[(?P<context>[^\]]+)\]\s+(?P<message>.+)$'
)
WINSTON_PATTERN = re.compile(
    r'^(?P<level>info|warn|error|debug|verbose):\s+(?P<message>[^{]+?)\s*(?P<meta>\{.*\})?$'
)
LEVEL_MAP = {'LOG': 'info', 'WARN': 'warn', 'ERROR': 'error', 'DEBUG': 'debug', 'VERBOSE': 'debug'}


class PreParser:
    def parse(self, message: str, service: str) -> dict:
        clean = ANSI_ESCAPE.sub('', message.strip())

        # Perfil A: NestJS
        m = NESTJS_PATTERN.match(clean)
        if m:
            return {
                'level': LEVEL_MAP.get(m.group('level'), 'info'),
                'context': m.group('context'),
                'message': f"[{m.group('context')}] {m.group('message')}",
                'profile': 'nestjs',
            }

        # Perfil B: Winston simple
        m = WINSTON_PATTERN.match(clean)
        if m:
            meta = {}
            if m.group('meta'):
                try:
                    meta = json.loads(m.group('meta'))
                except json.JSONDecodeError:
                    pass
            return {
                'level': m.group('level'),
                'context': meta.get('context', service),
                'message': m.group('message').strip(),
                'profile': 'winston',
            }

        # Formato desconocido: pasa el raw a Drain directamente
        return {
            'level': 'info',
            'context': service,
            'message': clean,
            'profile': 'unknown',
        }
```

**Verificar:**
```bash
