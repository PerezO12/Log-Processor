## Orden de implementación (escribe en este orden exacto)

### Paso 1 — `processor/settings.py`

Por qué primero: todos los demás módulos lo importan. Sin settings, nada compila.

```python
from pydantic import BaseModel
from pydantic_settings import BaseSettings, SettingsConfigDict
import yaml
from pathlib import Path


class LokiSettings(BaseModel):
    url: str = "http://loki:3100"
    query_step: str = "60s"
    max_lines: int = 10000
    timeout_seconds: int = 30


class AlertManagerSettings(BaseModel):
    url: str = "http://alertmanager:9093"
    webhook_path: str = "/api/v2/alerts"
    timeout_seconds: int = 10


class ProcessorSettings(BaseModel):
    schedule_interval_minutes: int = 5
    history_days: int = 7
    threshold_k: float = 3.0
    min_observations: int = 10
    services: list[str] = []


class DrainSettings(BaseModel):
    depth: int = 4
    similarity_threshold: float = 0.4
    max_children: int = 100
    extra_delimiters: list[str] = []
    state_save_path: str = "./drain_state"
    state_save_interval: int = 5


class DBSCANSettings(BaseModel):
    eps: float = 0.5
    min_samples: int = 2
    metric: str = "euclidean"


class MetricsSettings(BaseModel):
    enabled: bool = True
    port: int = 8000
    host: str = "0.0.0.0"


class Settings(BaseSettings):
    model_config = SettingsConfigDict(
        env_prefix="PROCESSOR_",
        env_nested_delimiter="__",
    )

    loki: LokiSettings = LokiSettings()
    alertmanager: AlertManagerSettings = AlertManagerSettings()
    processor: ProcessorSettings = ProcessorSettings()
    drain: DrainSettings = DrainSettings()
    dbscan: DBSCANSettings = DBSCANSettings()
    metrics: MetricsSettings = MetricsSettings()

    @classmethod
    def from_yaml(cls, path: str = "config.yaml") -> "Settings":
        p = Path(path)
        if p.exists():
            with open(p) as f:
                data = yaml.safe_load(f)
            return cls.model_validate(data)
        return cls()


# Singleton accesible desde cualquier modulo
settings = Settings.from_yaml()
```

**Verificar:**
```bash
python -c "from processor.settings import settings; print(settings.loki.url)"
# Debe imprimir: http://loki:3100
```

