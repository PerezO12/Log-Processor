### Paso 7 — `processor/alert_publisher.py`

Envía alertas a AlertManager vía webhook (formato Prometheus Alertmanager API v2).

```python
import httpx
import time
from .settings import settings


class AlertPublisher:
    def __init__(self):
        self.url = settings.alertmanager.url + settings.alertmanager.webhook_path

    async def publish(self, anomalies: list[dict]) -> bool:
        if not anomalies:
            return True

        alerts = []
        for a in anomalies:
            alerts.append({
                "labels": {
                    "alertname": "LogAnomalyDetected",
                    "service": a.get("service", "unknown"),
                    "severity": a.get("severity", "warning"),
                    "template": a.get("template", "unknown")[:100],
                    "cluster_id": str(a.get("cluster_id", -1)),
                },
                "annotations": {
                    "summary": f"Anomalia en {a.get('service')}: {a.get('template', '')[:80]}",
                    "description": (
                        f"Frecuencia actual: {a.get('current', '?')}. "
                        f"μ={a.get('mu', '?')} σ={a.get('sigma', '?')} "
                        f"z={a.get('z_score', '?')}"
                    ),
                },
                "startsAt": __import__('datetime').datetime.utcnow().isoformat() + "Z",
            })

        try:
            async with httpx.AsyncClient(timeout=settings.alertmanager.timeout_seconds) as client:
                resp = await client.post(self.url, json=alerts)
                return resp.status_code in (200, 201)
        except httpx.RequestError as e:
            # Loguear el error pero no interrumpir el ciclo
            return False
```

