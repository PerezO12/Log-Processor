p = PreParser()

nestjs = '[Nest] 1  - 15/01/2024, 10:30:05   ERROR [ExceptionHandler] Unauthorized: invalid token'
winston = 'error: Stripe webhook validation failed {\"context\":\"WebhookHandler\",\"service\":\"midas-server\"}'

print(p.parse(nestjs, 'gateway'))
print(p.parse(winston, 'midas-server'))
"
