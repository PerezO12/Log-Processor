### Paso 2 — `processor/loki_client.py`

Por qué segundo: es la puerta de entrada a los datos. Sin este módulo, no hay nada que procesar.

```python
import httpx
import time
from typing import Iterator
from .settings import settings

LogEntry = dict  # {"timestamp": int_ns, "message": str, "labels": dict}


class LokiClient:
    def __init__(self, url: str | None = None):
        self.base_url = url or settings.loki.url
        self._client = httpx.AsyncClient(
            base_url=self.base_url,
            timeout=settings.loki.timeout_seconds,
        )

    async def query_range(
        self,
        logql: str,
        minutes: int | None = None,
        start_ns: int | None = None,
        end_ns: int | None = None,
    ) -> list[LogEntry]:
        now_ns = int(time.time() * 1e9)
        end = end_ns or now_ns
        start = start_ns or (end - (minutes or settings.processor.schedule_interval_minutes) * 60 * int(1e9))

        entries = []
        params = {
            "query": logql,
            "start": start,
            "end": end,
            "limit": settings.loki.max_lines,
            "step": settings.loki.query_step,
            "direction": "backward",
        }

        resp = await self._client.get("/loki/api/v1/query_range", params=params)
        resp.raise_for_status()
        data = resp.json()

        for stream in data.get("data", {}).get("result", []):
            labels = stream.get("stream", {})
            for ts_str, msg in stream.get("values", []):
                entries.append({
                    "timestamp": int(ts_str),
                    "message": msg,
                    "labels": labels,
                })

        return entries

    async def get_labels(self) -> list[str]:
        resp = await self._client.get("/loki/api/v1/labels")
        resp.raise_for_status()
        return resp.json().get("data", [])

    async def health(self) -> bool:
        try:
            resp = await self._client.get("/ready")
            return resp.status_code == 200
        except Exception:
            return False

    async def close(self):
        await self._client.aclose()
```

**Verificar (con `docker compose up -d` corriendo):**
