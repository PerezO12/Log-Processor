    '[ExceptionHandler] Unauthorized: expired token',
    '[GrpcClient] Retrying connection to identity:50051 (attempt 1)',
    '[GrpcClient] Retrying connection to identity:50051 (attempt 2)',
    '[GrpcClient] Retrying connection to control:50052 (attempt 1)',
]

for msg in messages:
    r = p.process(msg)
    print(f'  [{r[\"cluster_id\"]}] {r[\"template\"]}  (new={r[\"is_new_template\"]})')
"
# Esperado: mensajes similares agrupados con <*> en los tokens variables
