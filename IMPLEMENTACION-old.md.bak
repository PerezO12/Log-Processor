from processor.loki_client import LokiClient

async def test():
    c = LokiClient('http://localhost:3100')
    ok = await c.health()
    print('Loki healthy:', ok)
    labels = await c.get_labels()
    print('Labels:', labels)
    logs = await c.query_range('{job=\"docker\"}', minutes=5)
    print(f'Logs found: {len(logs)}')
    if logs:
        print('Sample:', logs[0]['message'][:80])
    await c.close()

asyncio.run(test())
"
```

