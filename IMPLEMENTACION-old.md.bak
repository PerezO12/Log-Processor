### Paso 4 — `processor/drain_parser.py`

Wrapper de `drain3` con persistencia de estado en disco.

```python
from drain3 import TemplateMiner
from drain3.template_miner_config import TemplateMinerConfig
from drain3.file_persistence import FilePersistence
from pathlib import Path
from .settings import settings


class DrainParser:
    def __init__(self):
        config = TemplateMinerConfig()
        config.drain_depth = settings.drain.depth
        config.drain_sim_th = settings.drain.similarity_threshold
        config.drain_max_children = settings.drain.max_children
        config.parametrize_numeric_tokens = True

        persistence_dir = Path(settings.drain.state_save_path)
        persistence_dir.mkdir(parents=True, exist_ok=True)

        self.miner = TemplateMiner(
            persistence_handler=FilePersistence(str(persistence_dir / "drain_state.bin")),
            config=config,
        )
        self._cycle_count = 0

    def process(self, message: str) -> dict:
        result = self.miner.add_log_message(message)
        return {
            'cluster_id': result.cluster.cluster_id,
            'template': result.cluster.get_template(),
            'is_new_template': result.change_type == "cluster_created",
        }

    def save_state(self):
        # drain3 con FilePersistence guarda automaticamente en cada add_log_message.
        # Este metodo existe para llamadas manuales o al cerrar.
        pass

    def get_all_templates(self) -> list[dict]:
        return [
            {'id': c.cluster_id, 'template': c.get_template(), 'size': c.size}
            for c in self.miner.drain.id_to_cluster.values()
        ]
```

