### Paso 9 — `processor/metrics.py`

```python
from prometheus_client import start_http_server, Counter, Gauge, Histogram
from .settings import settings

# Metricas del procesador (alimentan Dashboard 3 del Cap. II II.3.4)
LOGS_PROCESSED = Counter("processor_logs_total", "Total de logs procesados", ["service"])
ANOMALIES_DETECTED = Counter("processor_anomalies_total", "Anomalias detectadas", ["service", "severity"])
CYCLE_DURATION = Histogram("processor_cycle_duration_seconds", "Duracion de cada ciclo de analisis")
TEMPLATES_ACTIVE = Gauge("processor_drain_templates_active", "Plantillas activas en Drain")
LAST_CYCLE_TIMESTAMP = Gauge("processor_last_cycle_timestamp", "Timestamp del ultimo ciclo exitoso")


def start_metrics_server():
    start_http_server(settings.metrics.port, addr=settings.metrics.host)


def record_cycle(logs_count: int, anomalies_count: int):
    import time
    LAST_CYCLE_TIMESTAMP.set(time.time())
```

