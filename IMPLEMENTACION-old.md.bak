p = DrainParser()
# Carga el estado guardado
templates = p.get_all_templates()
print(f'Templates activas: {len(templates)}')
for t in templates[:10]:
    print(f'  [{t[\"id\"]}] size={t[\"size\"]} template={t[\"template\"][:80]}')
"
```

