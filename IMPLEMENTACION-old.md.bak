### Paso 8 — `processor/main.py` (integración final)

```python
import asyncio
import argparse
import structlog
from apscheduler.schedulers.asyncio import AsyncIOScheduler
from .settings import settings
from .loki_client import LokiClient
from .pre_parser import PreParser
from .drain_parser import DrainParser
from .threshold import ThresholdDetector
from .dbscan_cluster import cluster_anomalies
from .alert_publisher import AlertPublisher
from .metrics import start_metrics_server, record_cycle

log = structlog.get_logger()


async def run_cycle(
    loki: LokiClient,
    parser: PreParser,
    drain: DrainParser,
    detector: ThresholdDetector,
    publisher: AlertPublisher,
):
    log.info("cycle_start")

    # 1. Consultar logs de todos los servicios
    entries = await loki.query_range(
        query='{env=~"production|local"}',
        minutes=settings.processor.schedule_interval_minutes,
    )
    log.info("logs_fetched", count=len(entries))

    # 2. Pre-parsear y agrupar por (service, template)
    freq: dict[tuple, int] = {}
    parsed_entries = []
    for entry in entries:
        service = entry["labels"].get("service", "unknown")
        parsed = parser.parse(entry["message"], service)
        result = drain.process(parsed["message"])
        key = (service, result["cluster_id"])
        freq[key] = freq.get(key, 0) + 1
        parsed_entries.append({**parsed, **result, "service": service})

    # 3. Detectar anomalias por plantilla
    anomalies = []
    for (service, template_id), current_freq in freq.items():
        hist = await detector.get_historical_frequencies(service, template_id)
        result = detector.detect_anomalies(current_freq, hist)
        if result["is_anomaly"]:
            template = next(
                (e["template"] for e in parsed_entries
                 if e["service"] == service and e["cluster_id"] == template_id),
                f"template_{template_id}"
            )
            anomalies.append({
                **result,
                "service": service,
                "template_id": template_id,
                "template": template,
            })

    log.info("anomalies_detected", count=len(anomalies))

    # 4. Agrupar con DBSCAN
    if anomalies:
        anomalies = cluster_anomalies(anomalies)

        # 5. Publicar a AlertManager
        await publisher.publish(anomalies)

    record_cycle(len(entries), len(anomalies))
    log.info("cycle_end", processed=len(entries), anomalies=len(anomalies))


async def main_async(run_once: bool = False):
    loki = LokiClient()
    parser = PreParser()
    drain = DrainParser()
    detector = ThresholdDetector(loki)
    publisher = AlertPublisher()

    if run_once:
        await run_cycle(loki, parser, drain, detector, publisher)
        await loki.close()
        return

    scheduler = AsyncIOScheduler()
    scheduler.add_job(
        run_cycle,
        "interval",
        minutes=settings.processor.schedule_interval_minutes,
        args=[loki, parser, drain, detector, publisher],
        id="main_cycle",
    )
    scheduler.start()
    log.info("scheduler_started", interval_minutes=settings.processor.schedule_interval_minutes)

    try:
        await asyncio.Event().wait()
    finally:
        scheduler.shutdown()
        await loki.close()


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--once", action="store_true", help="Ejecuta un ciclo y termina")
    args = parser.parse_args()

    if settings.metrics.enabled:
        from .metrics import start_metrics_server
        start_metrics_server()

    asyncio.run(main_async(run_once=args.once))


if __name__ == "__main__":
    main()
```

