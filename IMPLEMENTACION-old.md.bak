### Paso 5 — `processor/threshold.py`

Calcula μ y σ sobre el histórico y aplica la regla k·σ.

```python
import numpy as np
import asyncio
from collections import defaultdict
from .loki_client import LokiClient
from .settings import settings


class ThresholdDetector:
    def __init__(self, loki: LokiClient):
        self.loki = loki

    async def get_historical_frequencies(
        self, service: str, template_id: int
    ) -> np.ndarray:
        """
        Consulta Loki para obtener la frecuencia de la plantilla
        en ventanas de W minutos durante los ultimos H dias.
        Devuelve array de frecuencias historicas.
        """
        W = settings.processor.schedule_interval_minutes
        H_days = settings.processor.history_days
        total_windows = int(H_days * 24 * 60 / W)

        # En la implementacion real, aqui van queries LogQL por ventana.
        # Para no saturar Loki, usa una sola query de rango y agrupa por ventana.
        # Placeholder: devuelve array vacio si no hay historico suficiente.
        return np.array([])

    def detect_anomalies(
        self,
        current_freq: int,
        historical_freqs: np.ndarray,
        k: float | None = None,
    ) -> dict:
        k = k or settings.processor.threshold_k
        min_obs = settings.processor.min_observations

        if len(historical_freqs) < min_obs:
            return {"is_anomaly": False, "reason": "insufficient_history"}

        mu = float(np.mean(historical_freqs))
        sigma = float(np.std(historical_freqs))

        if sigma == 0:
            # Si sigma es 0, solo hay anomalia si hay un cambio brusco (> 0 cuando siempre fue 0)
            is_anomaly = current_freq > 0 and mu == 0
            return {
                "is_anomaly": is_anomaly,
                "mu": mu, "sigma": 0, "current": current_freq,
                "severity": "critical" if is_anomaly else "normal",
            }

        z_score = (current_freq - mu) / sigma
        upper = mu + k * sigma
        lower = mu - k * sigma

        if current_freq > upper:
            severity = "critical" if z_score > k + 1 else "warning"
        elif current_freq < lower:
            severity = "info"  # caida, posible degradacion
        else:
            severity = "normal"

        return {
            "is_anomaly": severity != "normal",
            "severity": severity,
            "mu": round(mu, 2),
            "sigma": round(sigma, 2),
            "current": current_freq,
            "upper": round(upper, 2),
            "lower": round(lower, 2),
            "z_score": round(z_score, 2),
        }
```

---

### Paso 6 — `processor/dbscan_cluster.py`

Agrupa anomalías para distinguir eventos aislados (ruido) de patrones recurrentes.

```python
import numpy as np
from sklearn.cluster import DBSCAN
from sklearn.preprocessing import LabelEncoder
from .settings import settings


def cluster_anomalies(anomalies: list[dict]) -> list[dict]:
    """
    anomalies: lista de dicts con campos:
        service, template_id, severity, z_score, timestamp_ns
    Devuelve los mismos dicts con campo 'cluster_id' añadido (-1 = ruido).
    """
    if len(anomalies) < 2:
        for a in anomalies:
            a["cluster_id"] = -1
        return anomalies

    # Vectorizar: [z_score, severity_code, service_code]
    sev_map = {"info": 0, "warning": 1, "critical": 2}
    svc_enc = LabelEncoder()
    services = svc_enc.fit_transform([a["service"] for a in anomalies])

    X = np.column_stack([
        [a.get("z_score", 0) for a in anomalies],
        [sev_map.get(a.get("severity", "info"), 0) for a in anomalies],
        services,
    ])

    labels = DBSCAN(
        eps=settings.dbscan.eps,
        min_samples=settings.dbscan.min_samples,
        metric=settings.dbscan.metric,
    ).fit_predict(X)

    for anomaly, label in zip(anomalies, labels):
        anomaly["cluster_id"] = int(label)

    return anomalies
```

